# Gemini API Key (Get a free key at https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: GitHub Personal Access Token (raises rate limit from 60 to 5000 req/hr)
# Highly recommended for production to avoid 403 Forbidden errors.
GITHUB_TOKEN=your_github_token_here

# Gemini Model to use (Optional, defaults to gemini-2.5-pro)
GEMINI_MODEL=gemini-2.5-pro

# Server Port (Optional, defaults to 5000)
PORT=5000
